{
  "manifest_version": 3,
  "name": "Link-Lens: AI Web-Guard",
  "version": "1.0",
  "description": "See before you step. Surf without fear. Protects from phishing and malware.",
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}